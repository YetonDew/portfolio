---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getCollection("about");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | YetonDew Portfolio`}>
  <section
    class="bg-primary dark:bg-zinc-900 min-h-screen px-4 py-6 sm:px-7 sm:py-8"
  >
    <div class="mb-6 flex justify-center sm:mb-8">
      <a
        href="/"
        transition:name="about-hero-button"
        aria-label="Close and go back"
        title="Back to home"
        class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-white/90 text-black shadow-lg shadow-black/10 backdrop-blur-md transition-transform duration-300 ease-out hover:scale-110 dark:bg-zinc-950/80 dark:text-white"
      >
        <svg
          viewBox="0 0 24 24"
          class="h-8 w-8"
          fill="none"
          stroke="currentColor"
          stroke-width="2.4"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M6 6L18 18"></path>
          <path d="M18 6L6 18"></path>
        </svg>
      </a>
    </div>
    <div
      class="mx-auto max-w-4xl rounded-2xl bg-primary p-6 dark:bg-zinc-900 sm:p-10"
    >
      <div class="mb-8 flex items-start justify-between gap-4">
        <div>
          <p
            class="text-xs uppercase tracking-[0.35em] text-zinc-500 dark:text-zinc-400"
          >
            {entry.data.label}
          </p>
          <h1 class="mt-3 text-3xl text-zinc-900 dark:text-white sm:text-4xl">
            {entry.data.title}
          </h1>
        </div>
      </div>

      <article class="markdown-content text-zinc-700 dark:text-zinc-300">
        <Content />
      </article>
    </div>
  </section>
</Layout>

<style>
  .markdown-content :global(p) {
    margin: 0 0 1rem;
    line-height: 1.8;
  }

  .markdown-content :global(h2),
  .markdown-content :global(h3) {
    color: inherit;
    margin: 1.5rem 0 0.75rem;
  }
</style>
