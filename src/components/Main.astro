---
import Github from "../assets/github.astro";
import Linkedin from "../assets/linkedin.astro";
import Mail from "../assets/mail.astro";
import Toggle from "./Toggle.astro";
import Mapa from "./Map.jsx";
import Slider from "./Slider.astro";
import LikeButton from "./LikeButton.jsx";
---

<section class="bg-primary-light dark:bg-black min-h-screen py-10 px-4 sm:px-7">
  <div
    class="w-full flex flex-col gap-4 lg:h-[90vh] lg:grid lg:grid-cols-10 lg:grid-rows-6"
  >
    <!-- Intro -->
    <div
      class="bg-primary dark:bg-zinc-900 rounded-2xl lg:col-span-3 lg:row-span-2"
    >
      <section
        class="flex flex-col justify-center items-start h-full py-10 px-6 gap-4 lg:py-20 lg:px-10"
      >
        <h1 class="text-3xl dark:text-white">Hi, I'm Jefferson ──</h1>
        <p class="dark:text-zinc-400">
          Software Engineer, currently studying at 42 Warsaw & Computer Science
          at PJATK.
        </p>
      </section>
    </div>

    <!-- Map -->
    <div
      class="h-48 lg:h-auto bg-primary dark:bg-zinc-900 rounded-2xl overflow-hidden lg:col-span-2 lg:row-span-2 lg:col-start-4"
    >
      <Mapa client:only="react" />
    </div>

    <!-- Cell 3 -->
    <div
      class="h-24 lg:h-auto bg-primary dark:bg-zinc-900 rounded-2xl lg:col-span-2 lg:row-span-2 lg:col-start-6"
    >
      3
    </div>

    <!-- Social icons: flex row on mobile, dissolve into grid on lg via display:contents -->
    <div class="flex gap-4 h-14 lg:contents">
      <div
        class="flex-1 bg-purple-500 dark:bg-zinc-900 rounded-2xl lg:col-start-8"
      >
        <a
          class="text-white dark:text-zinc-400 h-full w-full flex justify-center items-center dark:hover:text-white transition-colors"
          href="https://github.com/YetonDew"
          target="_blank"
          aria-label="github"
          title="github YetonDew"
        >
          <Github />
        </a>
      </div>
      <div
        class="flex-1 bg-blue-dark dark:bg-zinc-900 rounded-2xl lg:col-start-9"
      >
        <a
          class="text-white dark:text-zinc-400 h-full w-full flex justify-center items-center dark:hover:text-white transition-colors"
          href="https://www.linkedin.com/in/yeton/"
          target="_blank"
          aria-label="linkedin"
          title="linkedin YetonDew"
        >
          <Linkedin />
        </a>
      </div>
      <div
        class="flex-1 bg-orange dark:bg-zinc-900 rounded-2xl lg:col-start-10"
      >
        <a
          class="text-white dark:text-zinc-400 h-full w-full flex justify-center items-center dark:hover:text-white transition-colors"
          href="https://www.linkedin.com/in/yeton/"
          target="_blank"
          aria-label="mail"
          title="mail YetonDew"
        >
          <Mail />
        </a>
      </div>
    </div>

    <!-- Photo -->
    <div
      class="h-56 bg-primary dark:bg-zinc-900 rounded-2xl relative overflow-hidden lg:h-auto lg:col-span-2 lg:row-span-2 lg:col-start-1 lg:row-start-3"
    >
      <img
        src="/assets/me_light.jpg"
        alt="YetonDew"
        class="absolute -top-7 dark:hidden object-[center_-20%]"
      />
      <img
        src="/assets/me.jpg"
        alt="YetonDew"
        class="absolute -top-7 hidden dark:block"
      />
    </div>

    <!-- Cell 8 -->
    <div
      class="h-24 lg:h-auto bg-primary dark:bg-zinc-900 rounded-2xl lg:col-span-2 lg:row-span-2 lg:col-start-3 lg:row-start-3"
    >
      8
    </div>

    <!-- Orihuela project -->
    <div
      class="overflow-hidden h-48 lg:h-auto rounded-2xl
                bg-gradient-to-br from-cyan-500 via-cyan-200 to-cyan-700
                dark:from-gray-900 dark:via-cyan-700 dark:to-gray-900
                lg:col-span-3 lg:row-span-2 lg:col-start-8 lg:row-start-2"
    >
      <a href="#" class="relative block w-full h-full group">
        <img
          src="/assets/orihuela_iphone.png"
          alt="orihuela.pl"
          class="w-full scale-210 absolute -bottom-20 -right-20 group-hover:rotate-12 group-hover:scale-280 transition-transform"
        />
      </a>
    </div>

    <!-- Slider -->
    <div
      class="bg-white bg-[linear-gradient(to_right,#f0f0f0_1px,transparent_1px),linear-gradient(to_bottom,#f0f0f0_1px,transparent_1px)] bg-[size:6rem_4rem] dark:bg-zinc-950 dark:bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] dark:bg-[size:6rem_4rem] rounded-2xl flex justify-center items-center lg:col-span-3 lg:row-span-2 lg:col-start-5 lg:row-start-3"
    >
      <Slider />
    </div>

    <!-- Cell 11 -->
    <div
      class="relative h-24 lg:h-auto bg-primary dark:bg-zinc-900 rounded-2xl lg:col-span-3 lg:row-span-2 lg:col-start-1 lg:row-start-5"
    >
      <section
        class="flex flex-col justify-center items-start h-full py-10 px-6 gap-10 lg:py-20 lg:px-10"
      >
        <p class="dark:text-zinc-400">A B O U T</p>
        <h1 class="text-2xl dark:text-white">
          I enjoy taking on new challenges and finding solutions..
        </h1>
        <a
          href="#"
          aria-label="See more details"
          title="See more details"
          class="absolute bottom-4 right-4 flex h-12 w-12 items-center justify-center rounded-full bg-white/90 text-black shadow-lg shadow-black/10 backdrop-blur-md transition-transform duration-300 ease-out hover:scale-110 dark:bg-zinc-950/80 dark:text-white"
        >
          <svg
            viewBox="0 0 24 24"
            class="h-5 w-5"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M7 17L17 7"></path>
            <path d="M9 7h8v8"></path>
          </svg>
        </a>
      </section>
    </div>

    <!-- Cell 12 -->
    <div
      class="h-40 lg:h-auto bg-primary dark:bg-zinc-900 rounded-2xl lg:col-span-2 lg:row-span-2 lg:col-start-4 lg:row-start-5"
    >
      <LikeButton client:only="react" repo="YetonDew/portfolio" />
    </div>

    <!-- Toggle -->
    <div
      class="py-4 lg:py-0 bg-primary dark:bg-zinc-900 rounded-2xl flex justify-center items-center lg:col-span-2 lg:row-span-2 lg:col-start-6 lg:row-start-5"
    >
      <Toggle />
    </div>

    <!-- Lexis project -->
    <div
      class="h-64 lg:h-auto overflow-hidden rounded-2xl
                lg:col-span-3 lg:row-span-3 lg:col-start-8 lg:row-start-4"
    >
      <a
        href="#"
        class="overflow-hidden bg-gradient-to-br
                               from-blue-300 via-indigo-300 to-blue-200
                               dark:from-gray-900 dark:via-indigo-900 dark:to-gray-950
                               relative block w-full h-full group"
      >
        <img
          src="/assets/lexis_macbook.png"
          alt="biurolexis.pl"
          class="w-full scale-150 absolute bottom-10 -right-40 group-hover:-right-20 group-hover:scale-160 transition-all"
        />
      </a>
    </div>
  </div>
</section>
